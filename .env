# ============================================================
#  NXIO — .env
#  DO NOT COMMIT THIS FILE TO GITHUB
#  Copy .env.example and fill in your values
# ============================================================

# API Security
NXIO_API_KEY=change-this-to-a-strong-secret-key

# Environment: development | paper | production
NXIO_ENV=paper

# Database
DB_PATH=data/nxio.db

# Logging
LOG_LEVEL=INFO

# CORS — set to your dashboard URL (no trailing slash)
ALLOWED_ORIGIN=http://localhost:8000

# Paper Trading
PAPER_CAPITAL=100000

# Angel One (leave blank until live trading enabled)
ANGEL_API_KEY=
ANGEL_CLIENT_ID=
ANGEL_PASSWORD=